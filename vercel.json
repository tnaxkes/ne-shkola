{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.py" }
  ],
  "crons": [
    {
      "path": "/internal/reminders",
      "schedule": "*/5 * * * *"
    }
  ]
}
