APP_NAME=Drum School Booking
APP_URL=http://localhost:8000
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./drum_school.db
SECRET_KEY=change-me-in-production
SESSION_HTTPS_ONLY=false
SEED_ON_STARTUP=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_API_TOKEN=

TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=
# For Vercel deployment: set to your Vercel URL (https://your-app.vercel.app)
# Leave empty to run bot in polling mode locally
WEBHOOK_URL=
# Random secret shared between Vercel Cron and your app (protects /internal/reminders)
CRON_SECRET=

SALON_NAME=Не Школа Барабанов
SALON_PHONE=+7 (999) 000-00-00
SALON_ADDRESS=Москва, ул. Пример, д. 1
SALON_CONTACTS=@drum_admin

CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_FILE=

ENABLE_MASTERS=true
WORKDAY_START=10:00
WORKDAY_END=22:00
SLOT_STEP_MINUTES=60
APP_TIMEZONE=Europe/Moscow
RUN_HOST=127.0.0.1
RUN_PORT=8000
